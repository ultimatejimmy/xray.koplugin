msgstr "Частота фонового отримання:"

# en-hash: c0b6e5d7b1280ea464d54bf9cbfffd37
msgid "auto_update_sparse"
msgstr "Рідкісний: не частіше ніж раз на 30 хв"

# en-hash: 7f4cc9b44db70ed676e621f17b8228e3
msgid "auto_update_ultra"
msgstr "Ультра: перевіряє кожні %d сторінок"

